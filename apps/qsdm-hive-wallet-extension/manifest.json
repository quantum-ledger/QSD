{
  "manifest_version": 3,
  "name": "QSD Hive Wallet",
  "short_name": "QSD Wallet",
  "description": "Use one QSD wallet securely across Hive and connected websites.",
  "version": "0.2.0",
  "key": "",
  "permissions": ["nativeMessaging", "activeTab"],
  "icons": {
    "16": "QSD-hive-icon.png",
    "32": "QSD-hive-icon.png",
    "48": "QSD-hive-icon.png",
    "128": "QSD-hive-icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "QSD Hive Wallet",
    "default_popup": "popup.html",
    "default_icon": "QSD-hive-icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["provider.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
