# Copy to ngc.env (gitignored) — never commit real keys.
# NGC CLI API key from https://ngc.nvidia.com/
NGC_CLI_API_KEY=REPLACE_WITH_NGC_API_KEY
# After filling the key: .\scripts\verify-ngc-docker.ps1 (from this app folder)

# Optional: push proof bundles into a running QSD node (secret must match node's QSD_NGC_INGEST_SECRET)
# QSD_NGC_REPORT_URL=http://host.docker.internal:8080/api/v1/monitoring/ngc-proof
# QSD_NGC_INGEST_SECRET=REPLACE_WITH_RANDOM_32_BYTE_SECRET
# Optional: include QSD_node_id in proof JSON when node uses QSD_NVIDIA_LOCK_EXPECTED_NODE_ID
# QSD_NGC_PROOF_NODE_ID=my-validator-1
# QSD_NGC_PROOF_HMAC_SECRET=REPLACE_WITH_SEPARATE_RANDOM_32_BYTE_SECRET
# Optional: explicit PEM CA bundle. Otherwise certifi is used when installed,
# then the Python runtime's verified system/default trust configuration.
# QSD_NGC_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# When node has nvidia_lock_require_ingest_nonce: QSD_NGC_FETCH_CHALLENGE=true (GET /ngc-challenge before each bundle; 429 uses Retry-After, retries up to QSD_NGC_CHALLENGE_MAX_RETRIES, default 4)
# Optional: QSD_NGC_CHALLENGE_JITTER_MAX_SEC=8  # random sleep 0..8s before each challenge (NAT / many validators)
