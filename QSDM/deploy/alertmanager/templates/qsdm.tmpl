{{/*
  QSD Alertmanager templates.

  Renders both runbook_url AND dashboard_url annotations into
  every notification surface so the on-call operator has a one-
  click path from the incident message to (a) the markdown
  triage runbook and (b) the live Grafana panel for the firing
  alert.

  Templates exposed:

    QSD.title              - one-line incident title (used by
                               PagerDuty summary, Slack header,
                               email subject)
    QSD.text               - multi-line body (used by Slack
                               attachment text + PagerDuty
                               custom_details.description)
    QSD.slack.title        - Slack-specific title with severity
                               emoji prefix
    QSD.slack.titlelink    - clickable title -> dashboard
    QSD.pd.client          - PagerDuty client name
    QSD.pd.classname       - PagerDuty deduplication class

  Conventions used in the body templates:

    - {{ .CommonAnnotations.runbook_url }} surfaces the runbook
      markdown URL injected by alerts_QSD.example.yml.
    - {{ .CommonAnnotations.dashboard_url }} surfaces the per-
      runbook Grafana dashboard URL (auto-generated by
      scripts/gen_grafana_dashboards.py).
    - We use .CommonAnnotations rather than per-alert iteration
      because Alertmanager groups identical alertnames at the
      receiver level; the runbook + dashboard are properties of
      the alertname, not of individual instances.
*/}}


{{/* ----------------------------------------------------------
     Severity emoji
     ---------------------------------------------------------- */}}
{{ define "QSD.severityEmoji" -}}
{{- if eq .CommonLabels.severity "critical" -}}🚨
{{- else if eq .CommonLabels.severity "warning" -}}⚠️
{{- else if eq .CommonLabels.severity "info" -}}ℹ️
{{- else -}}🔔
{{- end -}}
{{ end }}


{{/* ----------------------------------------------------------
     One-line title
     ---------------------------------------------------------- */}}
{{ define "QSD.title" -}}
[{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] {{ .CommonLabels.alertname }} ({{ .CommonLabels.severity | toUpper }})
{{- end }}


{{/* ----------------------------------------------------------
     Multi-line body for Slack and PagerDuty.  Surfaces both URLs.
     ---------------------------------------------------------- */}}
{{ define "QSD.text" -}}
*Alert*: `{{ .CommonLabels.alertname }}`
*Severity*: `{{ .CommonLabels.severity }}`{{ if .CommonLabels.subsystem }}
*Subsystem*: `{{ .CommonLabels.subsystem }}`{{ end }}
*Status*: {{ .Status }}{{ if eq .Status "firing" }} ({{ .Alerts.Firing | len }} active){{ end }}

{{ range .Alerts -}}
{{ if .Annotations.summary }}*Summary*: {{ .Annotations.summary }}
{{ end -}}
{{ if .Annotations.description }}*Description*:
{{ .Annotations.description }}
{{ end -}}
{{ end -}}

{{ if .CommonAnnotations.runbook_url -}}
*Runbook*: <{{ .CommonAnnotations.runbook_url }}|Triage steps>
{{ end -}}
{{ if .CommonAnnotations.dashboard_url -}}
*Dashboard*: <{{ .CommonAnnotations.dashboard_url }}|Grafana panel>
{{ end -}}
{{- end }}


{{/* ----------------------------------------------------------
     Slack-specific bits
     ---------------------------------------------------------- */}}
{{ define "QSD.slack.title" -}}
{{ template "QSD.severityEmoji" . }} {{ template "QSD.title" . }}
{{- end }}

{{/*
  When the dashboard_url is set, make the Slack title a click-
  through to the live dashboard (operators reach the panel in
  one click). Falls back to runbook_url if dashboard is missing,
  then to a placeholder hash so Slack doesn't reject empty
  title_link.
*/}}
{{ define "QSD.slack.titlelink" -}}
{{ if .CommonAnnotations.dashboard_url -}}
{{ .CommonAnnotations.dashboard_url }}
{{- else if .CommonAnnotations.runbook_url -}}
{{ .CommonAnnotations.runbook_url }}
{{- else -}}
#
{{- end }}
{{- end }}

{{/*
  Slack attachment colour by severity. Aligns with Grafana
  dashboard threshold colours (critical=red, warning=orange,
  info=yellow).
*/}}
{{ define "QSD.slack.color" -}}
{{ if eq .Status "resolved" -}}
good
{{- else if eq .CommonLabels.severity "critical" -}}
danger
{{- else if eq .CommonLabels.severity "warning" -}}
warning
{{- else if eq .CommonLabels.severity "info" -}}
#9c9c9c
{{- else -}}
#cccccc
{{- end }}
{{- end }}


{{/* ----------------------------------------------------------
     PagerDuty-specific bits
     ---------------------------------------------------------- */}}
{{ define "QSD.pd.client" -}}QSD Alertmanager{{- end }}

{{/*
  PagerDuty `class` field — used for incident grouping in the
  PD dashboard. Subsystem label drives this when present, falls
  back to the QSD-default class.
*/}}
{{ define "QSD.pd.classname" -}}
{{ if .CommonLabels.subsystem -}}
{{ .CommonLabels.subsystem }}
{{- else -}}
QSD-default
{{- end }}
{{- end }}
