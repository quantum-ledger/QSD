# QSD Configuration File Example (YAML format, post-Major-Update 2026-04).
# Copy this file to QSD.yaml and customize as needed.
# Environment variables override config file values.
#
# See QSD/config/QSD.toml.example for the authoritative section-
# by-section commentary; this file mirrors its structure.

# Node role (Major Update Phase 2.1). Two-tier validator / miner model.
node:
  role: "validator"        # "validator" (default) or "miner"; env QSD_NODE_ROLE
  mining_enabled: false    # must be true for miner, false for validator

# Network Configuration
network:
  port: 4001
  bootstrap_peers: []
  # submesh_config: "config/micropayments.yml"  # optional; env QSD_SUBMESH_CONFIG overrides
    # - "127.0.0.1:4001"
    # - "192.168.1.100:4001"

# Storage Configuration
storage:
  type: "sqlite"  # Options: "sqlite" or "scylla"
  sqlite_path: "QSD.db"
  scylla_hosts:
    - "127.0.0.1"
  scylla_keyspace: "QSD"

# Monitoring Configuration
monitoring:
  dashboard_port: 8081
  log_viewer_port: 9000  # avoid clashing with api.port when using HTTP on 8080
  log_file: "QSD.log"
  log_level: "INFO"  # Options: "DEBUG", "INFO", "WARN", "ERROR"
  # metrics_scrape_secret: ""  # optional Prometheus scrape auth for /api/metrics/prometheus
  # strict_dashboard_auth: false  # production: fail closed on JWT init failure (see QSD.toml.example)

# API Server Configuration
api:
  port: 8443
  enable_tls: true
  tls_cert_file: ""  # Path to TLS certificate file
  tls_key_file: ""    # Path to TLS private key file
  # NGC sidecar: load QSD_NGC_INGEST_SECRET from a secret store with a unique random value
  # NVIDIA-lock: require recent GPU-attested proof for mint/send/create-token
  # nvidia_lock: false
  # nvidia_lock_max_proof_age: "15m"
  # nvidia_lock_expected_node_id: ""  # optional; match QSD_NGC_PROOF_NODE_ID on sidecar
  # nvidia_lock_proof_hmac_secret: "<replace-with-random-32-byte-secret>"  # match sidecar
  # nvidia_lock_require_ingest_nonce: false
  # nvidia_lock_gate_p2p: false  # optional: gate libp2p transaction storage (with nvidia_lock); env QSD_NVIDIA_LOCK_GATE_P2P
  # nvidia_lock_ingest_nonce_ttl: "10m"
  # jwt_hmac_secret: "<replace-with-separate-random-32-byte-secret>"  # env: QSD_JWT_HMAC_SECRET
  # strict_secrets: false  # true: reject weak secrets at startup (env QSD_STRICT_SECRETS overrides)
  # rate_limit_max_requests: 100  # global API limit per client window (health exempt)
  # rate_limit_window: "1m"
  # GET /api/v1/monitoring/ngc-challenge: ~15 req/min per client when nonce mode is on

# Wallet Configuration
wallet:
  initial_balance: 1000.0

# Governance Configuration
governance:
  proposal_file: "proposals.json"

# Performance Configuration
performance:
  transaction_interval: "30s"      # Duration between transaction checks
  health_check_interval: "30s"    # Duration between health checks

# Attestation transparency (Major Update §8.5). Transparency signal only;
# NOT a consensus rule. See QSD/docs/docs/NVIDIA_LOCK_CONSENSUS_SCOPE.md.
trust:
  disabled: false            # true -> /api/v1/trust/attestations/* returns 404
  fresh_within: "15m"        # attestations older than this are treated as stale
  refresh_interval: "10s"    # background cache rebuild cadence
  region_hint: ""            # "eu" | "us" | "apac" | "other" | ""
