# QSD Configuration File Example (post-Major-Update, 2026-04).
# Copy this file to QSD.toml and customize as needed.
# Environment variables override config file values.
#
# The QSD -> QSD rebrand added two new top-level sections:
#
#   [node]  -> two-tier validator / miner role model (§Phase 2.1).
#   [trust] -> opt-in attestation transparency surface (§8.5).
#
# Legacy env-var names (QSD_*) still work for every knob during the
# deprecation window documented in QSD/docs/docs/REBRAND_NOTES.md.

# -----------------------------------------------------------------------------
# Node role (Major Update Phase 2.1).
#
# Every QSD node picks exactly one of two roles:
#
#   validator : CPU-only; runs PoE + BFT; proposes / votes on blocks;
#               must NOT mine (mining_enabled = false).
#   miner     : GPU-based; runs additive PoW for Cell emission; never
#               proposes blocks; mining_enabled MUST be true.
#
# The server fails fast at startup when role and mining_enabled
# disagree, and `validator_only`-tagged builds refuse to start if
# mining_enabled is true regardless of role.
# -----------------------------------------------------------------------------
[node]
role = "validator"        # "validator" (default) or "miner". Env: QSD_NODE_ROLE.
mining_enabled = false    # must be true for miner role, false for validator.

# Network Configuration
[network]
port = 4001
bootstrap_peers = [
    # "127.0.0.1:4001",
    # "192.168.1.100:4001"
]
# submesh_config = "config/micropayments.toml"  # optional: seed DynamicSubmeshManager (env QSD_SUBMESH_CONFIG); multi-profile TOML uses [[submeshes]] tables

# Storage Configuration
[storage]
type = "sqlite"  # Options: "sqlite" or "scylla"
sqlite_path = "QSD.db"
scylla_hosts = ["127.0.0.1"]
scylla_keyspace = "QSD"

# Monitoring Configuration
[monitoring]
dashboard_port = 8081
log_viewer_port = 9000  # avoid clashing with [api] port when using HTTP on 8080
log_file = "QSD.log"
log_level = "INFO"  # Options: "DEBUG", "INFO", "WARN", "ERROR"
# metrics_scrape_secret = ""  # optional: Prometheus scrapes GET /api/metrics/prometheus with X-QSD-Metrics-Scrape-Secret or Bearer (env QSD_DASHBOARD_METRICS_SCRAPE_SECRET)
# strict_dashboard_auth = false  # if true (or QSD_DASHBOARD_STRICT_AUTH): when JWT auth fails to init, protected dashboard routes return 503; still allow Prometheus if metrics_scrape_secret is set

# API Server Configuration
[api]
port = 8443
enable_tls = true
tls_cert_file = ""  # Path to TLS certificate file
tls_key_file = ""    # Path to TLS private key file
# NGC sidecar proof ingest: set QSD_NGC_INGEST_SECRET from a secret store to a unique random value (see apps/QSD-nvidia-ngc/README.md)
# NVIDIA-lock (optional): require recent GPU-attested NGC proof before mint/send/create-token APIs
# nvidia_lock = false
# nvidia_lock_max_proof_age = "15m"
# nvidia_lock_expected_node_id = ""  # optional; must match sidecar QSD_NGC_PROOF_NODE_ID in proof JSON
# nvidia_lock_proof_hmac_secret = "<replace-with-random-32-byte-secret>"  # match sidecar QSD_NGC_PROOF_HMAC_SECRET
# nvidia_lock_require_ingest_nonce = false  # if true: GET /api/v1/monitoring/ngc-challenge + single-use nonce per ingest; proof consumed after one lock pass (requires HMAC secret)
# nvidia_lock_gate_p2p = false  # if true (with nvidia_lock): drop libp2p-received txs after PoE validation unless a qualifying proof exists (non-consuming check; env QSD_NVIDIA_LOCK_GATE_P2P)
# nvidia_lock_ingest_nonce_ttl = "10m"
# jwt_hmac_secret = "<replace-with-separate-random-32-byte-secret>"  # non-CGO JWT/request-signing HMAC
# strict_secrets = false  # if true: reject secrets < 16 chars or charming123* prefix (or set env QSD_STRICT_SECRETS=true; overrides file)
# Global HTTP API rate limit (per IP or X-API-Key); health routes exempt (env QSD_API_RATE_LIMIT_MAX / WINDOW)
# rate_limit_max_requests = 100
# rate_limit_window = "1m"
# GET /api/v1/monitoring/ngc-challenge is rate-limited to ~15/min per client when ingest nonce is used (see deploy/README.md)

# Wallet Configuration
[wallet]
initial_balance = 1000.0

# Governance Configuration
[governance]
proposal_file = "proposals.json"

# Performance Configuration
[performance]
transaction_interval = "30s"      # Duration between transaction checks
health_check_interval = "30s"    # Duration between health checks

# -----------------------------------------------------------------------------
# Attestation transparency (Major Update §8.5).
#
# Controls the opt-in /api/v1/trust/attestations/* endpoints and the
# landing-page / dashboard widgets that scrape them. This is a
# transparency signal, NOT a consensus rule — see
# QSD/docs/docs/NVIDIA_LOCK_CONSENSUS_SCOPE.md for the boundary.
#
# Default behavior (empty or missing [trust] block):
#   - endpoints enabled, 15 m freshness window, 10 s background refresh,
#     no region hint.
#
# Set disabled = true (or env QSD_TRUST_DISABLED=1) to make the
# endpoints return HTTP 404 on this node.
# -----------------------------------------------------------------------------
[trust]
disabled = false              # true -> /api/v1/trust/attestations/* returns 404
fresh_within = "15m"          # attestations older than this are treated as stale
refresh_interval = "10s"      # background cache rebuild cadence
region_hint = ""              # "eu" | "us" | "apac" | "other" | "" (coarse bucket)
