{
  "name": "QSD-sdk",
  "version": "0.3.1",
  "description": "Official JavaScript / Node.js SDK for the QSD HTTP API (native coin: Cell / CELL). Feature parity with sdk/go.",
  "main": "QSD.js",
  "types": "QSD.d.ts",
  "exports": {
    ".": {
      "types": "./QSD.d.ts",
      "require": "./QSD.js",
      "default": "./QSD.js"
    }
  },
  "scripts": {
    "test": "node --test QSD.test.js",
    "prepublishOnly": "node --test QSD.test.js"
  },
  "keywords": [
    "QSD",
    "cell",
    "blockchain",
    "quantum-safe",
    "post-quantum",
    "ml-dsa",
    "dilithium",
    "ledger",
    "sdk",
    "client"
  ],
  "author": "QSD authors",
  "license": "MIT",
  "homepage": "https://QSD.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantum-ledger/QSD.git",
    "directory": "QSD/source/sdk/javascript"
  },
  "bugs": {
    "url": "https://github.com/quantum-ledger/QSD/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "QSD.js",
    "QSD.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
